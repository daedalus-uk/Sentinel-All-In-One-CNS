      },
      {
        "principalId": "9e0fd891-09ec-4ed6-8f29-f766a8372ccf",
        "roleDefinitionId": "fb1c8493-542b-48eb-b624-b4c8fea62acd",
        "principalIdDisplayName": "MS-Pim-SOCteam"
      },
      {
